# ──────────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=zenodolite
POSTGRES_USER=zenodolite
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://zenodolite:changeme@postgres:5432/zenodolite

# ──────────────────────────────────────────────
# MinIO (object storage)
# ──────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme123
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_BUCKET=zenodo-lite

# ──────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ──────────────────────────────────────────────
# OpenSearch
# ──────────────────────────────────────────────
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
OPENSEARCH_INDEX=zenodo-lite-records

# ──────────────────────────────────────────────
# FastAPI / JWT
# ──────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRY_DAYS=30

# ──────────────────────────────────────────────
# ORCID OAuth
# Register a free Public API at: https://orcid.org/developer-tools
# Set redirect URI to: http://your-domain/auth/callback
# ──────────────────────────────────────────────
ORCID_CLIENT_ID=APP-XXXXXXXXXXXXXXXX
ORCID_CLIENT_SECRET=your-orcid-client-secret
ORCID_REDIRECT_URI=http://localhost/auth/callback
ORCID_BASE_URL=https://orcid.org

# ──────────────────────────────────────────────
# App URLs
# ──────────────────────────────────────────────
FRONTEND_URL=http://localhost
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173

# ──────────��───────────────────────────────────
# Observability
# ──────────────────────────────────────────────
# LOG_LEVEL controls structlog output (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO
